####################################
# Kubernetes
####################################

K8S_VERSION="1.34"

####################################
# Cluster
####################################

CLUSTER_NAME="homelab"

CONTROL_PLANE_ENDPOINT=""

POD_CIDR="10.244.0.0/16"
SERVICE_CIDR="10.96.0.0/12"

SINGLE_NODE=true

####################################
# Container Runtime
####################################

CONTAINER_RUNTIME="containerd"

####################################
# Helm
####################################

INSTALL_HELM=true
HELM_VERSION="3.18.6"

####################################
# Cilium
####################################

INSTALL_CILIUM=true

CILIUM_VERSION="1.18.1"

CILIUM_KUBE_PROXY_REPLACEMENT=true

ENABLE_HUBBLE=true
ENABLE_HUBBLE_UI=true
ENABLE_PROMETHEUS=true

####################################
# Ingress NGINX
####################################

INSTALL_INGRESS=true

INGRESS_NGINX_VERSION="4.13.2"

####################################
# MetalLB
####################################

INSTALL_METALLB=false

METALLB_VERSION="0.15.2"

METALLB_IP_RANGE="192.168.178.240-192.168.178.250"

####################################
# Cert Manager
####################################

INSTALL_CERT_MANAGER=false

CERT_MANAGER_VERSION="1.18.2"

####################################
# Metrics Server
####################################

INSTALL_METRICS_SERVER=true

METRICS_SERVER_VERSION="3.13.0"

####################################
# Logging
####################################

LOG_LEVEL="INFO"

####################################
# Bootstrap
####################################

AUTO_REMOVE_CONTROL_PLANE_TAINT=true

WAIT_TIMEOUT="600"

####################################
# Optional
####################################

INSTALL_DASHBOARD=false
INSTALL_ARGOCD=false
INSTALL_LONGHORN=false
INSTALL_RANCHER=false
